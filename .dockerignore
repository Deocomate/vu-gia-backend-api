# ============================================================================
# Build output / Kết quả build — rebuilt inside the image, never copy in.
# ============================================================================
target/
build/
*.jar
!.mvn/wrapper/maven-wrapper.jar

# ============================================================================
# Local upload storage — never bake data into the image; it lives in a volume.
# ============================================================================
data/

# ============================================================================
# Version control & CI / Quản lý mã nguồn & CI
# ============================================================================
.git/
.gitignore
.gitattributes
.github/

# ============================================================================
# IDE & editor / Trình soạn thảo
# ============================================================================
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
.apt_generated/
.sts4-cache/
.springBeans

# ============================================================================
# Docker & docs / Docker & tài liệu
# ============================================================================
Dockerfile
.dockerignore
docker-compose*.yml
*.md
HELP.md

# ============================================================================
# OS / Logs / Temp
# ============================================================================
.DS_Store
Thumbs.db
*.log
tmp/
