# Copy to .env and fill in real values. Never commit .env.

# --- MySQL (service "db") ---
MYSQL_ROOT_PASSWORD=changeme
DB_USERNAME=root

# --- Local file storage ---
# Public domain/IP clients use to reach this server. Must NOT be localhost in
# production (image links returned to clients would be unreachable).
APP_STORAGE_PUBLIC_URL=http://localhost:8080

# --- JWT ---
APP_JWT_SECRET=

# --- OAuth2 Google (optional) ---
GOOGLE_CLIENT_ID=

# --- Mail (optional) ---
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=
MAIL_PASSWORD=
APP_MAIL_FROM=

# --- VietQR payment ---
VIETQR_BASE_URL=https://vietqr.app/img
VIETQR_BANK=MBBank
VIETQR_ACCOUNT=
VIETQR_HOLDER=
VIETQR_TEMPLATE=compact

# --- SePay webhook ---
SEPAY_WEBHOOK_SECRET=
